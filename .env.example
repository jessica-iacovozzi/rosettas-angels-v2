# Site
SITE_URL=https://www.rosettasangels.org

# Cloudinary (cloud name is public — used in the browser)
PUBLIC_CLOUDINARY_CLOUD_NAME=rosettasangels

# EmailJS (client-side; PUBLIC_ keys are inlined into the bundle)
PUBLIC_EMAILJS_PUBLIC_KEY=
PUBLIC_EMAILJS_SERVICE_ID=
PUBLIC_EMAILJS_VOLUNTEER_TEMPLATE_ID=
PUBLIC_EMAILJS_CONTACT_TEMPLATE_ID=

# reCAPTCHA v3
PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Google Sheets via Apps Script Web App webhook
# Deploy a doPost(e) Apps Script as a Web App; paste its /exec URL here.
GSHEETS_WEBHOOK_URL=
# Shared secret you set in your Apps Script's PropertiesService (validated server-side)
GSHEETS_SHARED_SECRET=

# Donorbox campaign (hard-coded per spec, override here if it changes)
PUBLIC_DONORBOX_CAMPAIGN=help-families-in-need-this-holiday-season
