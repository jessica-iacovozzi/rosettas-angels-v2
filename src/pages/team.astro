---
import BaseLayout from '~/layouts/BaseLayout.astro';
import TestimonialsCarousel from '~/islands/TestimonialsCarousel.tsx';
import { getImageUrl } from '~/lib/cloudinary';

const LEADERS = [
  {
    id: 'grace',
    name: 'Grace',
    role: 'Logistics & Planning',
    bio: 'Grace takes care of the rationing, the planning, the asking and the organizing — turning a year of intentions into a December of delivered baskets.',
  },
  {
    id: 'tony',
    name: 'Tony',
    role: 'Operations & Outreach',
    bio: 'Tony collects donations, advertises, does the research and moves things around — the engine that keeps the brigade rolling.',
  },
  {
    id: 'yan',
    name: 'Yan',
    role: 'Volunteer Coordinator',
    bio: 'Yan never stops helping out — packing, sorting, driving — and his hard work never goes unnoticed.',
  },
];

const TESTIMONIALS = [
  {
    name: 'Angelo',
    role: 'Volunteer',
    quote: "It's the smile that you see on the face of these people. That moment, that is what makes this so special — for me and for them.",
  },
  {
    name: 'Jinny',
    role: 'Volunteer',
    quote: "There's families where the kids sleep on the floor. To bring them a basket and watch their faces… you carry it home with you for weeks.",
  },
  {
    name: 'Kim',
    role: 'Volunteer',
    quote: "I am moved at how grateful they are. Every door, every thank-you — it reminds me why we keep coming back every December.",
  },
  {
    name: 'Anna Maria',
    role: 'Volunteer',
    quote: "That's what Christmas is all about. Not gifts under a tree — gifts at someone else's door. Rosetta knew that better than anyone.",
  },
];
---

<BaseLayout
  title="Our Team"
  description="Meet the dedicated leaders and volunteers who make Rosetta's Angels possible."
>
  <section class="section team-hero" aria-labelledby="team-heading">
    <div class="container">
      <p class="eyebrow">Our Team</p>
      <h1 id="team-heading" class="display-lg">
        The hands behind the <span class="underline-mark">baskets</span>.
      </h1>
      <p class="lede">
        Meet the dedicated individuals who lead Rosetta's Angels with passion
        and commitment — and the volunteers who breathe life into every December.
      </p>
    </div>
  </section>

  <section class="section section--tight team-leaders" aria-labelledby="leaders-heading">
    <div class="container">
      <h2 id="leaders-heading" class="display team-leaders__heading">Leadership</h2>
      <ul class="team-leaders__grid" role="list">
        {LEADERS.map((leader) => (
          <li class="team-leader reveal">
            <figure class="photo-card team-leader__photo">
              <img
                src={getImageUrl(`team/${leader.id}`, 480)}
                srcset={`${getImageUrl(`team/${leader.id}`, 320)} 320w, ${getImageUrl(`team/${leader.id}`, 480)} 480w, ${getImageUrl(`team/${leader.id}`, 800)} 800w`}
                sizes="(min-width: 1024px) 22rem, (min-width: 640px) 30vw, 70vw"
                alt={`Portrait of ${leader.name}, ${leader.role} at Rosetta's Angels`}
                width="400"
                height="400"
                loading="lazy"
                decoding="async"
              />
            </figure>
            <div class="team-leader__body">
              <h3 class="team-leader__name display-lg">{leader.name}</h3>
              <p class="team-leader__role small-caps">{leader.role}</p>
              <p class="team-leader__bio">{leader.bio}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section--wheat team-testimonials" aria-labelledby="t-heading">
    <div class="container">
      <header class="team-testimonials__header">
        <p class="eyebrow">Voices from the Brigade</p>
        <h2 id="t-heading" class="display">
          Hear from the volunteers who make our mission <span class="underline-mark">possible</span>.
        </h2>
      </header>
      <TestimonialsCarousel client:visible testimonials={TESTIMONIALS} />
    </div>
  </section>

  <section class="section section--evergreen team-cta" aria-labelledby="cta-heading">
    <div class="container team-cta__inner">
      <h2 id="cta-heading" class="display team-cta__heading">Join Our Team</h2>
      <p class="team-cta__copy">Help us make a difference in our community.</p>
      <div class="team-cta__buttons">
        <a href="/volunteer" class="btn btn--primary btn--lg">Volunteer</a>
        <a href="/#contactForm" class="btn btn--secondary btn--on-dark btn--lg">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .team-hero { background: var(--color-cream); padding-block-end: var(--space-6); }
  .team-hero h1 { color: var(--color-evergreen); margin-block: var(--space-4) var(--space-5); }

  .team-leaders__heading {
    color: var(--color-evergreen);
    margin-block-end: var(--space-12);
    text-align: center;
  }
  .team-leaders__grid {
    list-style: none;
    display: grid;
    gap: var(--space-10);
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) { .team-leaders__grid { grid-template-columns: repeat(3, 1fr); } }

  .team-leader { display: flex; flex-direction: column; gap: var(--space-5); align-items: flex-start; }
  .team-leader__photo {
    aspect-ratio: 1 / 1;
    width: min(20rem, 100%);
    align-self: center;
  }
  .team-leader__photo:nth-of-type(odd) { transform: rotate(-1.5deg); }
  .team-leader__photo:nth-of-type(even) { transform: rotate(1.5deg); }
  .team-leader__photo img { aspect-ratio: 1/1; object-fit: cover; }
  .team-leader__body { width: 100%; }
  .team-leader__name { color: var(--color-evergreen); }
  .team-leader__role { color: var(--color-amber-600); margin-block: var(--space-2) var(--space-3); display: block; }
  .team-leader__bio { color: var(--color-ink-soft); line-height: var(--lh-relaxed); }

  .team-testimonials__header { text-align: center; max-width: 42rem; margin: 0 auto; }
  .team-testimonials__header h2 { color: var(--color-evergreen); margin-block-start: var(--space-3); }

  .team-cta__inner { text-align: center; }
  .team-cta__heading { color: var(--color-cream); }
  .team-cta__copy { color: var(--color-on-dark-soft); margin-block: var(--space-4) var(--space-8); font-size: var(--fs-md); }
  .team-cta__buttons { display: inline-flex; flex-wrap: wrap; gap: var(--space-4); justify-content: center; }
</style>
