---
import { Image } from 'astro:assets';
import { getImageUrl } from '~/lib/cloudinary';
import { getLang, useTranslations } from '~/i18n';

const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);

const storyPhotos = [
  { id: 'gallery/2009', alt: "Photograph from the 2009 Rosetta's Angels holiday basket event" },
  { id: 'home/rosetta', alt: "Rosetta, founder in spirit of Rosetta's Angels" },
];
const missionPhotos = [
  { id: 'home/group', alt: "Rosetta's Angels volunteers group photo" },
  { id: 'banners/volunteer', alt: "Volunteer at a holiday basket event" },
];
---

<section class="section story-mission" aria-labelledby="story-heading">
  <div class="container story-mission__container">

    <!-- Row 1: Our Story — text left, images right -->
    <div class="story-mission__row story-row">
      <article class="story-mission__block reveal">
        <p class="eyebrow">{t.story.eyebrow}</p>
        <h2 id="story-heading" class="display story-mission__heading">
          {t.story.heading.before}<span class="underline-mark">{t.story.heading.accent}</span>{t.story.heading.after}
        </h2>
        <p class="lede">{t.story.body}</p>
      </article>

      <div class="story-mission__media reveal">
        {storyPhotos[0] && (
          <figure class="photo-card story-mission__photo story-mission__photo--a">
            <Image
              src={getImageUrl(storyPhotos[0].id, 800)}
              widths={[360, 560, 800]}
              sizes="(min-width: 1024px) 26rem, (min-width: 640px) 44vw, 65vw"
              width={800}
              height={1000}
              quality={72}
              loading="lazy"
              alt={storyPhotos[0].alt}
            />
          </figure>
        )}
        {storyPhotos[1] && (
          <figure class="photo-card story-mission__photo story-mission__photo--b">
            <Image
              src={getImageUrl(storyPhotos[1].id, 640)}
              widths={[280, 400, 640]}
              sizes="(min-width: 1024px) 18rem, (min-width: 640px) 35vw, 50vw"
              width={640}
              height={800}
              quality={72}
              loading="lazy"
              alt={storyPhotos[1].alt}
            />
          </figure>
        )}
      </div>
    </div>

    <!-- Row 2: Our Mission — images left, text right -->
    <div class="story-mission__row mission-row">
      <div class="story-mission__media reveal">
        {missionPhotos[0] && (
          <figure class="photo-card story-mission__photo story-mission__photo--a">
            <Image
              src={getImageUrl(missionPhotos[0].id, 800)}
              widths={[360, 560, 800]}
              sizes="(min-width: 1024px) 26rem, (min-width: 640px) 44vw, 65vw"
              width={800}
              height={1000}
              quality={72}
              loading="lazy"
              alt={missionPhotos[0].alt}
            />
          </figure>
        )}
        {missionPhotos[1] && (
          <figure class="photo-card story-mission__photo story-mission__photo--b">
            <Image
              src={getImageUrl(missionPhotos[1].id, 640)}
              widths={[280, 400, 640]}
              sizes="(min-width: 1024px) 18rem, (min-width: 640px) 35vw, 50vw"
              width={640}
              height={800}
              quality={72}
              loading="lazy"
              alt={missionPhotos[1].alt}
            />
          </figure>
        )}
      </div>

      <article class="story-mission__block reveal">
        <p class="eyebrow">{t.mission.eyebrow}</p>
        <h2 class="display story-mission__heading">
          {t.mission.heading.before}<span class="underline-mark">{t.mission.heading.accent}</span>{t.mission.heading.after}
        </h2>
        <p class="lede">{t.mission.body}</p>
      </article>
    </div>

  </div>
</section>

<style>
  .story-mission { background: var(--color-cream); }

  .story-mission__container {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .story-mission__row {
    display: grid;
    gap: var(--space-12);
    grid-template-columns: 1fr;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .story-row {
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
      gap: var(--space-16);
    }
    .mission-row {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
      gap: var(--space-16);
    }
  }

  .story-mission__media {
    position: relative;
    aspect-ratio: 4 / 3;
    max-width: 36rem;
    margin-inline: auto;
    width: 100%;
  }
  .story-mission__photo {
    position: absolute;
    margin: 0;
    transition: transform var(--duration-slow) var(--ease-out);
  }
  .story-mission__photo--a {
    inset-block-start: 0;
    inset-inline-start: 0;
    width: 76%;
    transform: rotate(-2deg);
    z-index: 1;
  }
  .story-mission__photo--b {
    inset-block-start: 32%;
    inset-inline-end: 0;
    width: 60%;
    transform: rotate(3.5deg);
    z-index: 2;
  }

  /* On mobile the mission row stacks: pull text above photos so it reads
     Story text → Story photos → Mission text → Mission photos */
  @media (max-width: 1023px) {
    .mission-row .story-mission__block { order: -1; }
    .story-mission__container { gap: var(--space-6); }
  }

  .story-mission__block { display: flex; flex-direction: column; }
  .story-mission__heading { color: var(--color-evergreen); }
  .story-mission__block .lede { margin-block-start: var(--space-5); }
</style>
