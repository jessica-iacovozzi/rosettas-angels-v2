---
import { getLang, useTranslations } from '~/i18n';

const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);

const STATS = [
  { value: 16, suffix: '' },
  { value: 300, suffix: '+' },
  { value: 50, suffix: '+' },
];
---

<section class="section stats section--evergreen" aria-labelledby="stats-heading">
  <div class="stats__wave stats__wave--top" aria-hidden="true">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,30 C240,0 480,60 720,30 C960,0 1200,60 1440,30 L1440,0 L0,0 Z" fill="#e8dfc8"/>
    </svg>
  </div>
  <div class="container stats__inner">
    <h2 id="stats-heading" class="sr-only">{t.stats.srLabel}</h2>
    <ul class="stats__grid" role="list">
      {STATS.map((s, i) => (
        <li class="stats__item">
          <span
            class="stats__value display-xl"
            data-target={s.value}
            data-suffix={s.suffix}
          >
            0{s.suffix}
          </span>
          <span class="stats__label small-caps">{t.stats.labels[i]}</span>
        </li>
      ))}
    </ul>
    <p class="stats__since reveal">
      <span class="underline-mark">{t.stats.sinceUnderlined}</span>{t.stats.sinceRest}
    </p>
  </div>
  <!-- Wave divider: transitions from evergreen (stats bg) to cream (next section) -->
  <div class="stats__wave" aria-hidden="true">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,60 L0,60 Z" fill="#faf4e8"/>
    </svg>
  </div>
</section>

<style>
  .stats {
    color: var(--color-cream);
    padding-block: 0;
  }

  .stats__inner {
    padding-block-start: var(--space-16);
    padding-block-end: 75px;
  }

  .stats__wave {
    display: block;
    line-height: 0;
    overflow: hidden;
  }
  .stats__wave svg {
    display: block;
    width: 100%;
    height: clamp(40px, 4vw, 70px);
  }
  .stats__wave--top { margin-top: -2px; }
  .stats__wave:not(.stats__wave--top) { margin-bottom: -2px; }
  .stats__grid {
    list-style: none;
    display: grid;
    gap: var(--space-10);
    grid-template-columns: 1fr;
    text-align: center;
  }
  @media (max-width: 1023px) { .stats__wave { display: none; } }
  @media (min-width: 768px) { .stats__grid { grid-template-columns: repeat(3, 1fr); } }

  .stats__item { display: flex; flex-direction: column; gap: var(--space-3); align-items: center; }
  .stats__value {
    color: var(--color-amber);
    line-height: 0.95;
    font-variant-numeric: tabular-nums;
  }
  .stats__label { color: var(--color-on-dark-soft); }

  .stats__since {
    margin-block-start: var(--space-12);
    text-align: center;
    font-family: var(--font-italic);
    font-style: italic;
    font-size: var(--fs-lg);
    color: var(--color-on-dark-soft);
  }
  .stats__since .underline-mark { color: var(--color-cream); }
</style>

<script>
  const REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const items = document.querySelectorAll<HTMLElement>('.stats__value');

  const fmtLocale = document.documentElement.lang === 'fr' ? 'fr-CA' : 'en-CA';
  function format(n: number, suffix: string) {
    return `${Math.round(n).toLocaleString(fmtLocale)}${suffix}`;
  }

  function animateOne(el: HTMLElement) {
    const target = Number(el.dataset.target ?? 0);
    const suffix = el.dataset.suffix ?? '';
    if (REDUCED) {
      el.textContent = format(target, suffix);
      return;
    }
    const duration = 2000;
    const start = performance.now();
    function tick(now: number) {
      const t = Math.min(1, (now - start) / duration);
      const eased = 1 - Math.pow(1 - t, 3); // easeOutCubic
      el.textContent = format(target * eased, suffix);
      if (t < 1) requestAnimationFrame(tick);
      else el.textContent = format(target, suffix);
    }
    requestAnimationFrame(tick);
  }

  if (!('IntersectionObserver' in window)) {
    items.forEach(animateOne);
  } else {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          animateOne(e.target as HTMLElement);
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.4 });
    items.forEach((el) => io.observe(el));
  }
</script>
