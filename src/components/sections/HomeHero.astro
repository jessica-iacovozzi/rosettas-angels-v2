---
import HeroVideoTile from '~/islands/HeroVideoTile.tsx';
import { getVideoUrl, getVideoThumbnail } from '~/lib/cloudinary';
import { HOME_BANNER_VIDEO_ID, FEATURE_VIDEO_ID } from '~/lib/gallery-assets';
import { getLang, useTranslations } from '~/i18n';
import { getRelativeLocaleUrl } from 'astro:i18n';

const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);

const bannerVideoUrl = getVideoUrl(HOME_BANNER_VIDEO_ID, 1920);
const bannerPosterMobile = getVideoThumbnail(HOME_BANNER_VIDEO_ID, 2, 828);
const bannerPosterDesktop = getVideoThumbnail(HOME_BANNER_VIDEO_ID, 2, 1920);

const featureVideoUrl = getVideoUrl(FEATURE_VIDEO_ID, 1280);
const featurePoster = getVideoThumbnail(FEATURE_VIDEO_ID, 39, 720);

const donateHref    = getRelativeLocaleUrl(lang, 'donate');
const volunteerHref = getRelativeLocaleUrl(lang, 'volunteer');
---

<section class="hero" aria-label="Welcome" data-dark-hero>
  <!-- Background video — muted, autoplaying, decorative.
       The poster ensures something paints before video data arrives. -->
  <video
    class="hero__video"
    muted
    loop
    playsinline
    preload="none"
    poster={bannerPosterMobile}
    aria-hidden="true"
    tabindex="-1"
    role="none"
    data-src={bannerVideoUrl}
    data-poster-desktop={bannerPosterDesktop}
  ></video>
  <div class="hero__scrim" aria-hidden="true"></div>

  <div class="hero__inner container--wide">
    <div class="hero__content">
      <p class="eyebrow hero__eyebrow">{t.hero.eyebrow}</p>
      <h1 class="display-xl hero__heading">
        {t.hero.headingBefore}<span class="underline-mark">{t.hero.headingAccent}</span><br />
        {t.hero.headingLine2}<br />
        {t.hero.headingLine3}
      </h1>
      <p class="hero__sub">{t.hero.sub}</p>

      <div class="hero__ctas">
        <a href={donateHref} class="btn btn--primary btn--lg">{t.hero.ctaDonate}</a>
        <a href={volunteerHref} class="btn btn--secondary btn--on-dark btn--lg">{t.hero.ctaVolunteer}</a>
      </div>
    </div>

    <aside class="hero__tile-wrap" aria-label={t.hero.videoAria}>
      <HeroVideoTile
        client:media="(min-width: 768px)"
        videoUrl={featureVideoUrl}
        posterUrl={featurePoster}
        label={t.hero.videoLabel}
      />
    </aside>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background: var(--color-evergreen-900);
    color: var(--color-cream);
    /* Pull the hero up behind the fixed header */
    margin-top: calc(-1 * var(--header-height));
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: stretch;
  }
  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    /* Slow-motion *feeling* — just slow the playback rate. Set via JS below. */
    filter: saturate(0.85) brightness(0.85);
  }
  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(110deg, rgba(14,33,23,0.78) 0%, rgba(14,33,23,0.55) 45%, rgba(14,33,23,0.25) 100%),
      radial-gradient(at 80% 100%, rgba(14,33,23,0) 0%, rgba(14,33,23,0.55) 70%);
    pointer-events: none;
  }
  .hero__inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    align-items: end;
    width: 100%;
    padding-block: clamp(6rem, 9vw, 10rem) clamp(3rem, 5vw, 6rem);
  }
  @media (min-width: 1024px) {
    .hero__inner {
      grid-template-columns: minmax(0, 1.4fr) minmax(0, 0.9fr);
      align-items: end;
    }
  }
  .hero__eyebrow { color: var(--color-amber); margin-block-end: var(--space-4); }
  .hero__heading {
    color: var(--color-cream);
    /* "joy" gets the underline; everything else inherits */
    text-shadow: 0 4px 24px rgba(0,0,0,0.35);
  }
  .hero__sub {
    margin-block-start: var(--space-6);
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: var(--color-on-dark-soft);
    max-width: 36ch;
  }
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-block-start: var(--space-8);
  }

  .hero__tile-wrap { justify-self: end; width: 100%; max-width: 22rem; }
  @media (max-width: 767px) {
    .hero__tile-wrap { display: none; } /* tile shown only ≥768px */
  }
  @media (min-width: 768px) and (max-width: 1023px) {
    .hero__tile-wrap {
      max-width: 18rem;
      position: absolute;
      right: var(--gutter);
      bottom: var(--space-8);
    }
  }

  :global(.hero-tile) {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    background: var(--color-evergreen);
    cursor: pointer;
    border: 3px solid var(--color-cream);
    transition: transform var(--duration-base) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out);
  }
  :global(.hero-tile:hover) { transform: translateY(-3px); box-shadow: 0 24px 40px rgba(0,0,0,0.45); }
  :global(.hero-tile img) { width: 100%; height: 100%; object-fit: cover; }
  :global(.hero-tile__badge) {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-pill);
    background: var(--color-amber);
    color: var(--color-evergreen-900);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-md);
  }
  :global(.hero-tile__caption) {
    position: absolute;
    inset-inline: 0;
    inset-block-end: 0;
    padding: var(--space-3) var(--space-4);
    background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.65) 100%);
    color: var(--color-cream);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    text-align: start;
  }

  /* Modal */
  :global(.video-modal) {
    position: fixed;
    inset: 0;
    background: rgba(14, 33, 23, 0.85);
    z-index: var(--z-modal);
    display: grid;
    place-items: center;
    padding: var(--space-4);
  }
  :global(.video-modal__panel) {
    position: relative;
    width: min(64rem, 100%);
    aspect-ratio: 16 / 9;
    background: #000;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }
  :global(.video-modal__panel video) { width: 100%; height: 100%; display: block; }
  :global(.video-modal__close) {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    z-index: 2;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-pill);
    background: rgba(14,33,23,0.9);
    color: var(--color-cream);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  :global(.video-modal__close:hover) { background: var(--color-amber); color: var(--color-evergreen-900); }

  @media (prefers-reduced-motion: reduce) {
    .hero__video { display: none; }
    .hero {
      background:
        linear-gradient(180deg, var(--color-evergreen-900) 0%, var(--color-evergreen) 100%);
    }
  }
</style>

<script>
  const v = document.querySelector<HTMLVideoElement>('.hero__video');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  
  function loadBackgroundVideo() {
    const tabletBreakpoint = getComputedStyle(document.documentElement)
      .getPropertyValue('--bp-md').trim() || '768px';
    if (!v || reducedMotion || !window.matchMedia(`(min-width: ${tabletBreakpoint})`).matches) {
      return;
    }
    
    const desktopPoster = v.dataset.posterDesktop;
    const videoSrc = v.dataset.src;
    
    if (!desktopPoster || !videoSrc) {
      console.warn('Missing video data attributes');
      return;
    }
    
    // Update poster first for immediate visual feedback
    v.poster = desktopPoster;
    
    // Load video with proper error handling
    v.src = videoSrc;
    v.playbackRate = 0.55;
    
    const handlePlay = () => { v.playbackRate = 0.55; };
    const handleError = (e: Event) => {
      console.warn('Background video failed to load:', e);
      // Keep desktop poster even if video fails
    };
    
    v.addEventListener('play', handlePlay);
    v.addEventListener('error', handleError);
    
    v.play().catch(() => {
      // Autoplay failed - user interaction required, but video is decorative so we can ignore
    });
    
    // Cleanup function to prevent memory leaks
    return () => {
      v.removeEventListener('play', handlePlay);
      v.removeEventListener('error', handleError);
    };
  }
  
  // Load video immediately if conditions are met
  loadBackgroundVideo();
</script>
