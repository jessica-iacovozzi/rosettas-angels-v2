---
import { getLang, useTranslations } from '~/i18n';
import { getRelativeLocaleUrl } from 'astro:i18n';

const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);
const volunteerHref = getRelativeLocaleUrl(lang, 'volunteer');
---

<section class="section how-we-help section--wheat" aria-labelledby="how-heading">
  <div class="container how-we-help__inner">
    <header class="how-we-help__header reveal">
      <p class="eyebrow">{t.howWeHelp.eyebrow}</p>
      <h2 id="how-heading" class="display">
        {t.howWeHelp.heading.before}<span class="underline-mark">{t.howWeHelp.heading.accent}</span>{t.howWeHelp.heading.after}
      </h2>
    </header>

    <ul class="how-we-help__grid" role="list">
      {t.howWeHelp.cards.map((a, i) => (
        <li class="how-we-help__card reveal">
          <div class="how-we-help__icon" aria-hidden="true">
            {i === 0 && (
<svg viewBox="0 0 32 32" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M16 8 C16 5 18 3 20 3"/>
  <path d="M16 7 C17 5 21 4 21 7 C21 9 17 9 16 7 Z"/>
  <path d="M16 9 C14 9 11 8 9 9 C6 10 4 13 4 17 C4 22 7 27 11 28 C13 29 14 28 16 28 C18 28 19 29 21 28 C25 27 28 22 28 17 C28 13 26 10 23 9 C21 8 18 9 16 9 Z"/>
</svg>
            )}
            {i === 1 && (
              <svg viewBox="0 0 32 32" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="5" y="11" width="22" height="16" rx="2"/>
                <path d="M11 11V8a5 5 0 0110 0v3"/>
                <path d="M5 19h22"/>
                <circle cx="16" cy="19" r="2" fill="currentColor" stroke="none"/>
              </svg>
            )}
            {i === 2 && (
<svg viewBox="0 0 32 32" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <rect x="4" y="15" width="24" height="13" rx="2"/>
  <rect x="3" y="10" width="26" height="6" rx="2"/>
  <line x1="16" y1="10" x2="16" y2="28"/>
  <path d="M16 10 C16 7 11 4 11 7 C11 10 16 10 16 10"/>
  <path d="M16 10 C16 7 21 4 21 7 C21 10 16 10 16 10"/>
  <circle cx="16" cy="10" r="1.4" fill="currentColor" stroke="none"/>
</svg>
            )}
          </div>
          <h3 class="how-we-help__title">{a.title}</h3>
          <p class="how-we-help__desc">{a.desc}</p>
        </li>
      ))}
    </ul>

    <div class="how-we-help__cta reveal">
      <a href={volunteerHref} class="btn btn--primary btn--lg">{t.howWeHelp.cta}</a>
    </div>
  </div>
</section>

<style>
  .how-we-help__header { text-align: center; max-width: 38rem; margin: 0 auto var(--space-12); }
  .how-we-help__header h2 { color: var(--color-evergreen); }
  .how-we-help__grid {
    list-style: none;
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
  }
  @media (min-width: 1024px) { .how-we-help__grid { grid-template-columns: repeat(3, 1fr); } }

  .how-we-help__card {
    background: var(--color-cream);
    padding: var(--space-8) var(--space-6);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    transition: transform var(--duration-base) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out);
  }
  .how-we-help__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .how-we-help__icon {
    width: 56px; height: 56px;
    border-radius: var(--radius-pill);
    background: var(--color-amber-100);
    color: var(--color-evergreen);
    display: inline-flex; align-items: center; justify-content: center;
    margin-block-end: var(--space-3);
  }
  .how-we-help__title {
    font-family: var(--font-display);
    font-weight: 800;
    text-transform: uppercase;
    text-align: center;
    letter-spacing: var(--tracking-tight);
    font-size: var(--fs-xl);
    color: var(--color-evergreen);
  }
  .how-we-help__desc { color: var(--color-ink-soft); font-size: var(--fs-sm); line-height: var(--lh-relaxed); text-align: center; }

  .how-we-help__cta { text-align: center; margin-block-start: var(--space-12); }
</style>
