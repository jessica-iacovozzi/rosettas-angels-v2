---
const campaign = import.meta.env.VITE_DONORBOX_CAMPAIGN ?? 'help-families-in-need-this-holiday-season';
const embedUrl = `https://donorbox.org/embed/${campaign}`;
---

<div class="donorbox" data-campaign={campaign}>
  <div class="donorbox__loading" data-loading-state aria-live="polite">
    <span class="donorbox__spinner" aria-hidden="true"></span>
  </div>

  <iframe
    src={embedUrl}
    name="donorbox"
    id="donorbox-iframe"
    allow="payment"
    seamless
    frameborder="0"
    scrolling="no"
    style="display:none;width:100%;min-width:310px;min-height:550px;"
    title="Donorbox donation form"
  ></iframe>
</div>

<style>
  .donorbox {
    position: relative;
    min-height: 36rem;
    background: var(--color-cream);
    padding: var(--space-4);
    overflow: hidden;
  }
  .donorbox__loading {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    color: var(--color-ink-muted);
    font-size: var(--fs-sm);
  }
  .donorbox__loading[hidden] { display: none; }
  .donorbox__spinner {
    width: 32px; height: 32px;
    border-radius: 50%;
    border: 3px solid var(--color-wheat);
    border-top-color: var(--color-amber);
    animation: spin 0.9s linear infinite;
  }
  @media (max-width: 767px) {
    .donorbox { padding: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .donorbox__spinner { animation: none; border-top-color: var(--color-amber); }
  }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>

<script>
  const SCRIPT_SRC = 'https://donorbox.org/widget.js';
  const MIN_VISIBLE_MS = 300;
  const mountedAt = Date.now();

  function revealIframe() {
    const elapsed = Date.now() - mountedAt;
    const wait = Math.max(0, MIN_VISIBLE_MS - elapsed);
    setTimeout(() => {
      const loading = document.querySelector<HTMLElement>('[data-loading-state]');
      const iframe = document.getElementById('donorbox-iframe') as HTMLIFrameElement | null;
      if (loading) loading.hidden = true;
      if (iframe) iframe.style.display = 'block';
    }, wait);
  }

  function showError() {
    const el = document.querySelector<HTMLElement>('[data-loading-state]');
    if (el) {
      el.textContent = '';
      const p = document.createElement('p');
      p.style.color = 'var(--color-error)';
      p.append('The donation form failed to load. Please refresh, or email ');
      const a = document.createElement('a');
      a.href = 'mailto:info@rosettasangels.org';
      a.textContent = 'info@rosettasangels.org';
      p.append(a);
      p.append(' to donate by another method.');
      el.append(p);
    }
  }

  function loadScript() {
    if (document.querySelector(`script[src="${SCRIPT_SRC}"]`)) {
      revealIframe();
      return;
    }
    const s = document.createElement('script');
    s.src = SCRIPT_SRC;
    s.setAttribute('paypalExpress', 'false');
    s.async = true;
    s.onload = revealIframe;
    s.onerror = showError;
    document.head.appendChild(s);
  }

  loadScript();

  // Cleanup on bfcache page-hide.
  window.addEventListener('pagehide', () => {
    const s = document.querySelector(`script[src="${SCRIPT_SRC}"]`);
    if (s?.parentNode) s.parentNode.removeChild(s);
  });
</script>
