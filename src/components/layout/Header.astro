---
import BrandMark from './BrandMark.astro';
import MobileMenu from '~/islands/MobileMenu.tsx';

const NAV = [
  { label: 'Home', href: '/' },
  { label: 'Gallery', href: '/gallery' },
  { label: 'Team', href: '/team' },
  { label: 'Volunteer', href: '/volunteer' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="site-header" role="banner">
  <div class="site-header__inner container--wide">
    <a class="site-header__brand" href="/" aria-label="Rosetta's Angels — home">
      <BrandMark />
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      <ul class="site-header__list">
        {NAV.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={["site-header__link", isActive(item.href) && "is-active"]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="site-header__cta-group">
      <a
        href="/donate"
        class:list={["btn btn--primary", isActive('/donate') && "is-active"]}
        aria-current={isActive('/donate') ? 'page' : undefined}
      >
        Donate
      </a>
      <div class="site-header__menu-trigger">
        <MobileMenu client:load items={NAV} currentPath={currentPath} />
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    z-index: var(--z-sticky);
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background-color var(--duration-base) var(--ease-out),
                border-color var(--duration-base) var(--ease-out);
  }
  .site-header.is-scrolled {
    background: var(--color-cream);
    border-bottom-color: var(--color-border);
    backdrop-filter: saturate(140%) blur(6px);
    -webkit-backdrop-filter: saturate(140%) blur(6px);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    min-height: var(--header-height);
  }
  .site-header__brand {
    text-decoration: none;
    color: var(--color-evergreen);
    flex: 0 0 auto;
    margin-inline-end: auto;
  }
  .site-header__brand:hover { color: var(--color-evergreen); }

  .site-header__nav { display: none; }
  @media (min-width: 1024px) {
    .site-header__nav { display: block; }
  }
  .site-header__list {
    list-style: none;
    display: flex;
    gap: var(--space-6);
    align-items: center;
  }
  .site-header__link {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--fs-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-evergreen);
    text-decoration: none;
    padding: var(--space-2) var(--space-1);
    position: relative;
    border-radius: var(--radius-sm);
    transition: color var(--duration-fast) var(--ease-out);
  }
  .site-header__link:hover { color: var(--color-amber-600); }

  /* Transparent + dark-hero variant: flip text to cream */
  :global(.site-header.is-on-dark .site-header__brand) { color: var(--color-cream); }
  :global(.site-header.is-on-dark .site-header__link) { color: var(--color-cream); }
  :global(.site-header.is-on-dark .site-header__link:hover) { color: var(--color-amber); }
  :global(.site-header.is-on-dark .mobile-menu__trigger) { color: var(--color-cream); }
  .site-header__link.is-active::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -2px;
    height: 3px;
    background: var(--color-amber);
    border-radius: 2px;
  }
  .site-header__cta-group {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex: 0 0 auto;
  }
  .site-header__menu-trigger { display: inline-flex; }
  @media (min-width: 1024px) {
    .site-header__menu-trigger { display: none; }
  }

  /* Mobile menu styles (here so they live with the header context) */
  :global(.mobile-menu__trigger) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--color-evergreen);
    background: transparent;
    border-radius: var(--radius-sm);
    position: relative;
    z-index: 0;
  }
  :global(.mobile-menu__trigger:hover) { color: var(--color-amber-600); }
  /* When menu is open, lift trigger above the panel (z-index 200) and make it visible on dark */
  :global(.mobile-menu__trigger.is-open) {
    z-index: 300;
    color: var(--color-cream);
  }
  :global(.mobile-menu__trigger.is-open:hover) { color: var(--color-amber); }

  :global(.mobile-menu__overlay) {
    position: fixed;
    inset: 0;
    background: rgba(14, 33, 23, 0.55);
    z-index: var(--z-overlay);
    animation: fade-in var(--duration-base) var(--ease-out);
  }
  :global(.mobile-menu__panel) {
    position: fixed;
    inset-block: 0;
    inset-inline-end: 0;
    width: min(20rem, 88vw);
    background: var(--color-evergreen);
    color: var(--color-cream);
    z-index: var(--z-modal);
    padding: calc(var(--header-height) + var(--space-6)) var(--space-6) var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    transform: translateX(100%);
    transition: transform var(--duration-base) var(--ease-out);
    box-shadow: var(--shadow-lg);
  }
  :global(.mobile-menu__panel.is-open) { transform: translateX(0); }
  :global(.mobile-menu__list) {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  :global(.mobile-menu__link) {
    display: block;
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: var(--tracking-tight);
    color: var(--color-cream);
    text-decoration: none;
    padding: var(--space-3) 0;
    border-radius: var(--radius-sm);
  }
  :global(.mobile-menu__link:hover),
  :global(.mobile-menu__link.is-active) { color: var(--color-amber); }
  :global(.mobile-menu__link.is-active) {
    text-decoration: underline;
    text-decoration-color: var(--color-amber);
    text-underline-offset: 0.18em;
    text-decoration-thickness: 0.12em;
  }
  :global(.mobile-menu__cta) { width: 100%; }

  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.mobile-menu__panel),
    :global(.mobile-menu__overlay) {
      transition: none !important;
      animation: none !important;
    }
    .site-header { transition: none !important; }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>('.site-header');
  if (header) {
    const hasDarkHero = !!document.querySelector('[data-dark-hero]');

    function updateHeader() {
      const atTop = window.scrollY <= 10;
      (header as HTMLElement).classList.toggle('is-scrolled', !atTop);
      (header as HTMLElement).classList.toggle('is-on-dark', atTop && hasDarkHero);
    }

    updateHeader();
    window.addEventListener('scroll', updateHeader, { passive: true });
  }
</script>
