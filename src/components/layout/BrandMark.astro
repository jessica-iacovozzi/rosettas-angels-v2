---
// Wordmark — display type, two-tone. Click area is the wrapping <a> in Header.

import { Image } from 'astro:assets';
import { getImageUrl } from '~/lib/cloudinary'
---

<span class="brandmark" aria-label="Rosetta's Angels — home">
   <Image
    class="brandmark__logo brandmark__logo--default"
    src={getImageUrl('logo/svg-logo.svg')}
    alt="Rosetta's Angels logo"
    width={100}
    height={100}
    aria-hidden="true"
    loading="eager"
  />
  <Image
    class="brandmark__logo brandmark__logo--white"
    src={getImageUrl('logo/svg-logo-white.svg')}
    alt="Rosetta's Angels logo"
    width={100}
    height={100}
    aria-hidden="true"
    loading="eager"
  />
  <span class="brandmark__text">
    <span class="brandmark__word">Rosetta's</span>
    <span class="brandmark__word brandmark__word--accent">Angels</span>
  </span>
</span>

<style>
  .brandmark {
    display: flex;
    width: fit-content;
    flex-direction: row;
    align-items: center;
    gap: var(--space-2);
  }
  .brandmark__logo {
    width: 5rem;
    height: 4.5rem;
    object-fit: contain;
    flex-shrink: 0;
  }
  .brandmark__logo--white { display: none; }
  .brandmark__text {
    font-family: var(--font-display);
    font-weight: 800;
    line-height: 0.95;
    text-transform: uppercase;
    display: inline-flex;
    flex-direction: column;
    letter-spacing: var(--tracking-tight);
    font-size: clamp(1.25rem, 1.05rem + 0.4vw, 1.5rem);
  }
  .brandmark__word { display: block; }
  .brandmark__word--accent {
    color: var(--color-amber);
    margin-inline-start: 0.4em;
  }
  /* White logo on dark backgrounds (footer, is-on-dark header) */
  :global([data-theme='dark']) .brandmark { color: var(--color-cream); }
  :global([data-theme='dark']) .brandmark__logo--default { display: none; }
  :global([data-theme='dark']) .brandmark__logo--white { display: block; }
  :global(.is-on-dark) .brandmark__logo--default { display: none; }
  :global(.is-on-dark) .brandmark__logo--white { display: block; }
</style>
