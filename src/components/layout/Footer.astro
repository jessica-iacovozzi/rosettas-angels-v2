---
import BrandMark from './BrandMark.astro';
import { getLang, useTranslations } from '~/i18n';
import { getRelativeLocaleUrl } from 'astro:i18n';

interface Props {
  /** Background color of the wave divider div — should match the last section above the footer. */
  waveBgColor?: string;
}

const { waveBgColor } = Astro.props;
const year = new Date().getFullYear();

const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);

const homeHref      = getRelativeLocaleUrl(lang, '');
const galleryHref   = getRelativeLocaleUrl(lang, 'gallery');
const teamHref      = getRelativeLocaleUrl(lang, 'team');
const volunteerHref = getRelativeLocaleUrl(lang, 'volunteer');
const donateHref    = getRelativeLocaleUrl(lang, 'donate');
const contactHref   = homeHref.replace(/\/$/, '') + '/#contactForm';
---

<!-- Wave divider into the dark footer -->
<div class="divider-wave" aria-hidden="true" style={waveBgColor ? `background-color: ${waveBgColor};` : undefined}>
  <svg viewBox="0 0 1440 80" preserveAspectRatio="none">
    <path
      d="M0,40 C240,80 480,0 720,32 C960,64 1200,16 1440,48 L1440,80 L0,80 Z"
      fill="#1f3d2e"
    />
  </svg>
</div>

<footer class="site-footer" role="contentinfo" data-theme="dark">
  <div class="container site-footer__inner">
    <div class="site-footer__brand-block site-footer__mobile-hide">
      <a href={homeHref} class="site-footer__brand" aria-label="Rosetta's Angels — home">
        <BrandMark />
      </a>
      <p class="site-footer__tagline">{t.footer.tagline}</p>
    </div>

    <nav class="site-footer__nav site-footer__mobile-hide" aria-label={t.footer.explore}>
      <h2 class="small-caps site-footer__heading">{t.footer.explore}</h2>
      <ul>
        <li><a href={homeHref}>{t.nav.home}</a></li>
        <li><a href={galleryHref}>{t.nav.gallery}</a></li>
        <li><a href={teamHref}>{t.footer.navTeam}</a></li>
        <li><a href={volunteerHref}>{t.nav.volunteer}</a></li>
        <li><a href={donateHref}>{t.nav.donate}</a></li>
      </ul>
    </nav>

    <div class="site-footer__contact site-footer__mobile-hide">
      <h2 class="small-caps site-footer__heading">{t.footer.contact}</h2>
      <ul>
        <li>
          <a href="mailto:info@rosettasangels.org">info@rosettasangels.org</a>
        </li>
        <li>Montreal, Quebec, Canada</li>
        <li>
          <a href={contactHref}>{t.footer.sendMessage}</a>
        </li>
      </ul>
    </div>

    <div class="site-footer__transparency">
      <h2 class="small-caps site-footer__heading">{t.footer.transparency}</h2>
      <p>{t.footer.transparencyText}</p>
    </div>
  </div>

  <div class="container site-footer__base">
    <small>
      © {year} Rosetta's Angels. {t.footer.rights}
      <span class="site-footer__credit">{t.footer.credit} <a href="https://jessicaiacovozzi.ca" target="_blank" rel="noopener">Jessica Iacovozzi</a>.</span>
    </small>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-evergreen);
    color: var(--color-on-dark);
    padding-block: var(--section-pad-y-tight);
  }
  .site-footer a {
    color: var(--color-on-dark);
    text-decoration-color: var(--color-amber);
  }
  .site-footer a:hover { color: var(--color-amber); }

  .site-footer__inner {
    display: grid;
    gap: var(--space-10);
    grid-template-columns: 1fr;
    align-items: start;
  }
  @media (min-width: 768px) {
    .site-footer__inner {
      grid-template-columns: 1.4fr 0.8fr 1fr 1.2fr;
    }
  }

  .site-footer__brand { display: inline-block; text-decoration: none; color: var(--color-cream); }
  .site-footer__tagline {
    margin-block-start: var(--space-4);
    color: var(--color-on-dark-soft);
    font-size: var(--fs-sm);
    line-height: var(--lh-relaxed);
    max-width: 28ch;
  }

  .site-footer__heading {
    color: var(--color-amber);
    margin-block-end: var(--space-4);
    display: block;
  }

  .site-footer__nav ul,
  .site-footer__contact ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: var(--fs-sm);
  }

  @media (max-width: 767px) {
    .site-footer__mobile-hide { display: none; }
  }

  .site-footer__transparency p {
    color: var(--color-on-dark-soft);
    font-size: var(--fs-sm);
    line-height: var(--lh-relaxed);
  }

  .site-footer__base {
    margin-block-start: var(--space-10);
    padding-block-start: var(--space-6);
    border-block-start: 1px solid rgba(250, 244, 232, 0.15);
    color: var(--color-on-dark-soft);
    display: flex;
    justify-content: center;
    font-size: var(--fs-xs);
  }
  .site-footer__credit { color: var(--color-on-dark-soft); }
  .site-footer__credit a { color: var(--color-on-dark-soft); }
</style>
