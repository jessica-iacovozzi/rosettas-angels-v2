---
import BaseLayout from '~/layouts/BaseLayout.astro';
import VolunteerForm from '~/islands/VolunteerForm.tsx';
import { EVENT_DATES, isSingleDayEvent, formatEventDate } from '~/lib/event-config';
import { getLang, useTranslations } from '~/i18n';

const lang = getLang(Astro.currentLocale);
const tv = useTranslations(lang).volunteer;

const ACTIVITY_ICONS = ['gift', 'basket', 'errand', 'truck'] as const;

const eventSchema = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: "Rosetta's Angels Holiday Basket Brigade",
  description: tv.heroLede,
  startDate: EVENT_DATES[0],
  endDate: EVENT_DATES[EVENT_DATES.length - 1],
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  organizer: {
    '@type': 'NGO',
    name: "Rosetta's Angels",
    url: 'https://www.rosettasangels.org',
  },
};
---

<BaseLayout
  title={tv.pageTitle}
  description={tv.metaDesc}
  footerWaveBgColor="var(--color-wheat)"
>
  <script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(eventSchema)} />

  <section class="section volunteer-hero section--evergreen" aria-labelledby="volunteer-heading">
    <div class="container">
      <p class="eyebrow volunteer-hero__eyebrow">{tv.heroEyebrow}</p>
      <h1 id="volunteer-heading" class="display-lg volunteer-hero__heading">
        {tv.heroHeading.before}<span class="underline-mark">{tv.heroHeading.accent}</span>{tv.heroHeading.after}
      </h1>
      <p class="lede volunteer-hero__lede">{tv.heroLede}</p>
    </div>
  </section>

  <section class="section section--tight event-details" aria-labelledby="event-heading">
    <div class="container">
      <h2 id="event-heading" class="display event-details__heading">{tv.detailsHeading}</h2>
      <dl class="event-details__list">
        <div>
          <dt class="small-caps">{tv.when}</dt>
          <dd>
            {EVENT_DATES.map((d) => (
              <span class="event-details__date">{formatEventDate(d)}</span>
            ))}
          </dd>
        </div>
        <div>
          <dt class="small-caps">{tv.where}</dt>
          <dd>{tv.whereDetail}</dd>
        </div>
        <div>
          <dt class="small-caps">{tv.contact}</dt>
          <dd><a href="mailto:info@rosettasangels.org">info@rosettasangels.org</a></dd>
        </div>
      </dl>

      <h3 class="event-details__sub display">{tv.activitiesHeading}</h3>
      <ul class="event-details__activities" role="list">
        {tv.activities.map((a, i) => (
          <li class="activity-card" style={`--accent: ${['#d77f1f','#a8331f','#1f3d2e','#b86614'][i]};`}>
            <div class="activity-card__icon" aria-hidden="true">
              {ACTIVITY_ICONS[i] === 'gift' && (
                <svg viewBox="0 0 32 32" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="4" y="12" width="24" height="14" rx="1"/>
                  <path d="M2 12h28M16 12v14M16 12c-2-4-7-4-7-1s5 1 7 1zM16 12c2-4 7-4 7-1s-5 1-7 1z"/>
                </svg>
              )}
              {ACTIVITY_ICONS[i] === 'basket' && (
                <svg viewBox="0 0 32 32" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 12h26l-2 14H5z"/>
                  <path d="M10 12l4-7M22 12l-4-7"/>
                  <path d="M12 17v5M16 17v5M20 17v5"/>
                </svg>
              )}
              {ACTIVITY_ICONS[i] === 'errand' && (
                <svg viewBox="0 0 32 32" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M6 7h14l3 9H6z"/>
                  <circle cx="11" cy="22" r="2.5"/>
                  <circle cx="22" cy="22" r="2.5"/>
                  <path d="M2 7h4M20 16h6"/>
                </svg>
              )}
              {ACTIVITY_ICONS[i] === 'truck' && (
                <svg viewBox="0 0 32 32" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="9" width="16" height="13" rx="1"/>
                  <path d="M19 13h6l4 4v5h-10z"/>
                  <circle cx="9" cy="24" r="2.5"/>
                  <circle cx="23" cy="24" r="2.5"/>
                </svg>
              )}
            </div>
            <strong class="activity-card__title">{a.title}</strong>
            <p class="activity-card__desc">{a.desc}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section--wheat volunteer-form-wrap" aria-labelledby="form-heading">
    <div class="container volunteer-form-wrap__inner">
      <header class="volunteer-form-wrap__header">
        <h2 id="form-heading" class="display volunteer-form-wrap__heading">
          {tv.formHeading.before}<span class="underline-mark">{tv.formHeading.accent}</span>{tv.formHeading.after}
        </h2>
        <p class="lede">{tv.formLede}</p>
        {isSingleDayEvent && (
          <p class="volunteer-form-wrap__note">{tv.singleDayNote}</p>
        )}
      </header>
      <div class="volunteer-form-wrap__card">
        <VolunteerForm client:visible strings={useTranslations(lang).forms.volunteer} />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .volunteer-hero { padding-block-end: var(--space-12); }
  .volunteer-hero__eyebrow { color: var(--color-amber); }
  .volunteer-hero__heading { color: var(--color-cream); margin-block: var(--space-4) var(--space-5); }
  .volunteer-hero__lede { color: var(--color-on-dark-soft); }

  .event-details__heading { color: var(--color-evergreen); margin-block-end: var(--space-8); }
  .event-details__list {
    display: grid;
    gap: var(--space-12);
    grid-template-columns: 1fr;
    margin-block-end: var(--space-12);
  }
  @media (min-width: 768px) { .event-details__list { grid-template-columns: repeat(3, 1fr); } }
  .event-details__list dt { color: var(--color-amber-600); margin-block-end: var(--space-2); display: block; }
  .event-details__list dd { color: var(--color-ink); font-size: var(--fs-md); }
  .event-details__date {
    display: inline-block;
    background: var(--color-amber-100);
    color: var(--color-evergreen);
    font-family: var(--font-display);
    font-weight: 800;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    letter-spacing: var(--tracking-tight);
  }

  .event-details__sub { color: var(--color-evergreen); margin-block-end: var(--space-6); font-size: var(--fs-xl); }
  .event-details__activities {
    list-style: none;
    display: grid;
    gap: var(--space-5);
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) { .event-details__activities { grid-template-columns: repeat(2, 1fr); } }

  .activity-card {
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-top: 4px solid var(--accent, var(--color-amber));
    border-radius: var(--radius-md);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition: transform var(--duration-base) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out);
  }
  .activity-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .activity-card__icon {
    width: 52px;
    height: 52px;
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--accent, var(--color-amber)) 12%, transparent);
    color: var(--accent, var(--color-amber));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-block-end: var(--space-1);
    flex-shrink: 0;
  }
  .activity-card__title {
    display: block;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--fs-lg);
    text-transform: uppercase;
    letter-spacing: var(--tracking-tight);
    color: var(--color-evergreen);
    line-height: var(--lh-snug);
  }
  .activity-card__desc {
    color: var(--color-ink-soft);
    font-size: var(--fs-sm);
    line-height: var(--lh-relaxed);
    margin: 0;
  }

  .volunteer-form-wrap__inner {
    display: grid;
    gap: var(--space-12);
    grid-template-columns: 1fr;
  }
  @media (min-width: 1024px) {
    .volunteer-form-wrap__inner {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.3fr);
      gap: var(--space-16);
      align-items: start;
    }
  }
  .volunteer-form-wrap__heading { color: var(--color-evergreen); margin-block-end: var(--space-5); }
  .volunteer-form-wrap__note {
    margin-block-start: var(--space-6);
    padding: var(--space-4);
    background: var(--color-cream);
    border-left: 4px solid var(--color-amber);
    border-radius: var(--radius-sm);
    color: var(--color-ink-soft);
    font-size: var(--fs-sm);
  }
  .volunteer-form-wrap__card {
    background: var(--color-cream);
    padding: var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }
  @media (min-width: 768px) { .volunteer-form-wrap__card { padding: var(--space-10); } }
</style>
