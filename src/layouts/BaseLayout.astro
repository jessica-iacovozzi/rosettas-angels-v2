---
import '~/styles/global.css';
import SkipLink from '~/components/layout/SkipLink.astro';
import Header from '~/components/layout/Header.astro';
import Footer from '~/components/layout/Footer.astro';
import { getLang } from '~/i18n';

interface Props {
  title: string;
  description: string;
  /** Set true on `/donate` to inject Donorbox preconnect early */
  preconnectDonorbox?: boolean;
  /** Background color of the wave divider div — should match the last section above the footer */
  footerWaveBgColor?: string;
}

const {
  title,
  description,
  preconnectDonorbox = false,
  footerWaveBgColor,
} = Astro.props;

const lang = getLang(Astro.currentLocale);
const fullTitle = title.includes("Rosetta's Angels") ? title : `${title} — Rosetta's Angels`;
const siteOrigin = (Astro.site ?? new URL('https://www.rosettasangels.org')).origin;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://www.rosettasangels.org').toString();
const ogImage = `${siteOrigin}/og_image.png`;

// hreflang alternates: compute the alternate-locale URL
const rawPath = Astro.url.pathname;
const enPath = lang === 'fr' ? rawPath.replace(/^\/fr\/?/, '/') || '/' : rawPath;
const frPath = lang === 'en' ? '/fr' + (rawPath === '/' ? '/' : rawPath) : rawPath;
const enHref = new URL(enPath, Astro.site ?? 'https://www.rosettasangels.org').toString();
const frHref = new URL(frPath, Astro.site ?? 'https://www.rosettasangels.org').toString();
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#1f3d2e" />
    <link rel="icon" href="/favicon.ico" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="fr" href={frHref} />
    <link rel="alternate" hreflang="x-default" href={enHref} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Rosetta's Angels" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts: preconnect first, then async load to avoid render-blocking.
         Fragment set:html bypasses Astro's JSX type-checker for the onload attribute. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <Fragment set:html={[
      '<link rel="preload" as="style"',
      ' href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@600;700;800;900&family=Fraunces:ital,wght@0,400;1,400;1,500&family=Inter:wght@400;500;600;700&display=swap"',
      " onload=\"this.onload=null;this.rel='stylesheet'\" />",
      '<noscript><link rel="stylesheet"',
      ' href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@600;700;800;900&family=Fraunces:ital,wght@0,400;1,400;1,500&family=Inter:wght@400;500;600;700&display=swap"',
      ' /></noscript>',
    ].join('')} />

    <link rel="preconnect" href="https://res.cloudinary.com" crossorigin />
    {preconnectDonorbox && (
      <>
        <link rel="preconnect" href="https://donorbox.org" crossorigin />
        <link rel="dns-prefetch" href="https://donorbox.org" />
      </>
    )}

    <slot name="head" />
  </head>
  <body>
    <SkipLink />
    <Header />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <Footer waveBgColor={footerWaveBgColor} />

    <!-- Reveal-on-scroll: respects prefers-reduced-motion via CSS -->
    <script>
      const els = document.querySelectorAll('.reveal');
      if (!('IntersectionObserver' in window) ||
          window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        els.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: '0px 0px -80px 0px', threshold: 0.05 }
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>

<style is:global>
  /* Fixed header: offset main so content starts below the bar */
  main {
    scroll-margin-top: var(--header-height);
    padding-top: var(--header-height);
  }
</style>
